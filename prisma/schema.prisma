generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  holdings  Holding[]
  orders    Order[]
  positions Position[]
}

model Holding {
  id     Int     @id @default(autoincrement())
  name   String
  qty    Int
  avg    Float
  price  Float
  net    String
  day    String
  isLoss Boolean @default(false)

  userId Int?          // optional
  user   User? @relation(fields: [userId], references: [id])
}

model Order {
  id    Int    @id @default(autoincrement())
  name  String
  qty   Int
  price Float
  mode  String

  userId Int?          // optional
  user   User? @relation(fields: [userId], references: [id])
}

model Position {
  id      Int     @id @default(autoincrement())
  product String
  name    String
  qty     Int
  avg     Float
  price   Float
  net     String
  day     String
  isLoss  Boolean

  userId Int?          // optional
  user   User? @relation(fields: [userId], references: [id])
}